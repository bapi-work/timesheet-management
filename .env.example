# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection - Required
# Format: postgresql://[user[:password]@][host][:port][/dbname]
# 
# Development/Local:
DATABASE_URL=postgresql://timesheet:timesheetpass@localhost:5433/timesheet_db
# 
# Production examples:
# AWS RDS: postgresql://user:password@timesheet-db.c123456.us-east-1.rds.amazonaws.com:5432/timesheet_db
# Azure: postgresql://user@server:password@timesheet-db.postgres.database.azure.com:5432/timesheet_db?sslmode=require
# GCP: postgresql://user:password@/timesheet_db?host=/cloudsql/project:region:instance

# PostgreSQL Docker Compose (for local development only)
POSTGRES_USER=timesheet
POSTGRES_PASSWORD=timesheetpass
POSTGRES_DB=timesheet_db

# ============================================
# REDIS CONFIGURATION
# ============================================
# Redis connection - Required for job queues & caching
# Format: redis[s]://[username[:password]@]host[:port][/database]
#
# Development/Local:
REDIS_URL=redis://:redispass@localhost:6380
#
# Production examples:
# AWS ElastiCache: redis://:password@timesheet-redis.123456.cache.amazonaws.com:6379
# Azure Cache: rediss://:password@timesheet.redis.cache.windows.net:6380
# GCP Memorystore: redis://:password@10.0.0.3:6379

# Redis Docker Compose (for local development only)
REDIS_PASSWORD=redispass

# ============================================
# JWT & SECURITY CONFIGURATION
# ============================================
# JWT Secret - CRITICAL: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters in production
# Rotate every 90 days
JWT_SECRET=change_me_in_production_super_secret_key_min_32_chars_a1b2c3d4e5f6

# JWT Refresh Secret - For refresh token generation
# Must be different from JWT_SECRET
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_different_f6e5d4c3b2a1

# JWT token expiration times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# EMAIL/SMTP CONFIGURATION
# ============================================
# SMTP Server Configuration
# IMPORTANT: Choose one of the providers below
#
# Option 1: Gmail (for development/small scale only)
# Setup: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=noreply@yourcompany.com

# Option 2: SendGrid (recommended for production)
# Setup: https://sendgrid.com/docs/for-developers/sending-email/integrating-with-the-smtp-api/
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.your-api-key-here
# SMTP_FROM=noreply@yourcompany.com

# Option 3: AWS SES (recommended if using AWS)
# Setup: https://docs.aws.amazon.com/ses/latest/dg/send-email-smtp.html
# SMTP_HOST=email-smtp.region.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-ses-smtp-user
# SMTP_PASS=your-ses-smtp-password
# SMTP_FROM=verified-email@yourcompany.com

# Option 4: Azure Communication Services
# Setup: https://learn.microsoft.com/en-us/azure/communication-services/quickstarts/email/send-email-smtp
# SMTP_HOST=smtp.communication.azure.com
# SMTP_PORT=587
# SMTP_USER=your-connection-string
# SMTP_PASS=your-auth-token
# SMTP_FROM=your-email@azure-communication.com

# Option 5: Mailgun
# Setup: https://documentation.mailgun.com/en/latest/user_manual.html#smtp-relay
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@your-domain.mailgun.org
# SMTP_PASS=your-mailgun-password
# SMTP_FROM=noreply@your-domain.mailgun.org

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Node environment
NODE_ENV=development
# Options: development, staging, production

# Application port
PORT=4000

# Frontend URL (where users access the application)
FRONTEND_URL=http://localhost:3001
# Production: https://ts-dev.digile.com

# API URL (for frontend to reach backend)
VITE_API_URL=http://localhost:4000/api
# Production: https://ts-dev.digile.com/api

# WebSocket URL (for real-time notifications)
VITE_WS_URL=ws://localhost:4000
# Production: wss://ts-dev.digile.com

# Logging level
LOG_LEVEL=debug
# Options: debug, info, warn, error

# ============================================
# OPTIONAL: AWS CONFIGURATION
# ============================================
# If using AWS services for file storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=timesheet-uploads-prod

# ============================================
# OPTIONAL: AZURE CONFIGURATION
# ============================================
# If using Azure services for file storage
AZURE_STORAGE_ACCOUNT_NAME=timesheetuploads
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_CONTAINER=uploads

# ============================================
# OPTIONAL: GCP CONFIGURATION
# ============================================
# If using GCP services for file storage
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_BUCKET=timesheet-uploads-prod

# ============================================
# OPTIONAL: SSO CONFIGURATION
# ============================================
# Microsoft Entra ID / Azure AD
# Setup: https://learn.microsoft.com/en-us/graph/tutorials/node
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# Google OAuth
# Setup: https://developers.google.com/identity/protocols/oauth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# OPTIONAL: MONITORING & ERROR TRACKING
# ============================================
# Sentry for error tracking
SENTRY_DSN=

# New Relic for APM
NEW_RELIC_LICENSE_KEY=

# DataDog API key
DATADOG_API_KEY=

# ============================================
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ============================================
# Slack notifications
SLACK_WEBHOOK_URL=

# Zapier or IFTTT webhooks
WEBHOOK_URL=

# ============================================
# ENVIRONMENT-SPECIFIC NOTES
# ============================================
# DEVELOPMENT:
# - Use simple passwords and insecure values
# - Enable debug logging
# - Use local services (Docker Compose)
# - Email service is optional (won't send in dev mode)
#
# STAGING:
# - Use strong secrets from secret manager
# - Use managed services (RDS, ElastiCache, etc.)
# - Enable monitoring
# - Test all integrations
# - Use staging email service account
#
# PRODUCTION:
# - NEVER commit .env to repository
# - Store secrets in cloud secret manager
# - Use managed services with HA/replication
# - Enable all monitoring and alerting
# - Use production email service account
# - Enable encryption at rest and in transit
# - Configure SSL/TLS certificates
# - Setup automated backups
# - Enable audit logging
#
# ============================================
# SECRETS MANAGEMENT
# ============================================
# For production, use cloud-native secret managers:
#
# AWS Secrets Manager:
# aws secretsmanager create-secret --name timesheet/jwt-secret --secret-string "value"
#
# Azure Key Vault:
# az keyvault secret set --vault-name timesheet-kv --name JWT-SECRET --value "value"
#
# GCP Secret Manager:
# echo -n "value" | gcloud secrets create JWT_SECRET --data-file=-
#
# Kubernetes Secrets:
# kubectl create secret generic timesheet-secrets --from-literal=JWT_SECRET=value
#
# ============================================
# GENERATION COMMANDS
# ============================================
# Generate strong JWT secret:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Generate strong password:
# openssl rand -base64 32
#
# ============================================
